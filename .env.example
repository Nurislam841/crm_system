# --- Phase 0 minimum env (required for the app to start) ---

# Postgres connection.
# On Vercel + Neon: DATABASE_URL = pooled (POSTGRES_PRISMA_URL), DIRECT_URL = unpooled (DATABASE_URL_UNPOOLED).
# Locally: both can point to the same URL.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/crm_school?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/crm_school?schema=public"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-32-bytes-of-randomness"
NEXTAUTH_URL="http://localhost:3000"

# Seed admin (used by prisma/seed.ts to create the first user)
SEED_ADMIN_EMAIL="admin@yourschool.kz"
SEED_ADMIN_PASSWORD="changeme-after-first-login"
SEED_ADMIN_NAME="Admin"
SEED_TENANT_SLUG="my_school"
SEED_TENANT_NAME="My School"

# --- Phase 0 optional (wire up when accounts exist) ---
# SENTRY_DSN=""

# --- Phase 1+ env (add when you reach the phase) ---
# CRON_SECRET=""
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_WEBHOOK_SECRET=""
# KASPI_API_KEY=""
