// Phase 0 — minimal schema: Tenant + User only.
// Sessions are JWT (no Session table needed). DB sessions can be added later.
// Full schema design lives in docs/04-database.md; tables are introduced
// phase-by-phase as features land.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  timezone  String   @default("Asia/Almaty")
  currency  String   @default("KZT")
  createdAt DateTime @default(now())

  users     User[]
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String
  fullName     String
  passwordHash String
  role         UserRole  @default(MANAGER)
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  tenant       Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@index([tenantId])
}

enum UserRole {
  ADMIN
  MANAGER
  TEACHER
}
